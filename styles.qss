/* === GLOBAL === */
QWidget {
    background-color: #0f172a;
    color: #e2e8f0;
    font-family: "Serif";
    font-size: 13px;
    selection-background-color: #06b6d4;
    selection-color: #0f172a;
}

/* === HEADER === */
QFrame#header {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1e293b, stop:1 #0f172a);
    border-bottom: 1px solid #334155;
}

QLabel#headerTitle {
    color: #06b6d4;
    font-size: 24px;
    font-weight: bold;
    letter-spacing: 3px;
    background: transparent;
}

/* === SIDEBAR === */
QFrame#sidebar {
    background: #1e293b;
    border-right: 1px solid #334155;
}

QLabel#sectionLabel {
    color: #94a3b8;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 6px 4px 2px 4px;
    background: transparent;
}

/* === PLAYLIST LIST === */
QListWidget#playlistList {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 4px;
    padding: 4px;
    outline: none;
}

QListWidget#playlistList::item {
    color: #cbd5e1;
    padding: 6px 8px;
    border-radius: 3px;
    margin: 1px 0px;
}

QListWidget#playlistList::item:selected {
    background: #334155;
    color: #06b6d4;
    border-left: 2px solid #d946ef;
}

QListWidget#playlistList::item:hover {
    background: #334155;
    color: #f8fafc;
}

/* === TRACK LIST === */
QListWidget#trackList {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 4px;
    padding: 2px;
    outline: none;
    font-size: 12px;
}

QListWidget#trackList::item {
    color: #cbd5e1;
    padding: 8px 10px;
    border-bottom: 1px solid #1e293b;
    border-radius: 0px;
}

QListWidget#trackList::item:selected {
    background: #334155;
    color: #06b6d4;
}

QListWidget#trackList::item:hover {
    background: #1e293b;
    color: #f8fafc;
}

/* === NOW PLAYING PANEL === */
QFrame#nowPlayingPanel {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0f172a, stop:0.5 #1e293b, stop:1 #0f172a);
}

QLabel#trackTitle {
    color: #f8fafc;
    font-size: 20px;
    font-weight: bold;
    background: transparent;
    padding: 4px;
}

QLabel#trackArtist {
    color: #94a3b8;
    font-size: 14px;
    background: transparent;
    padding: 2px;
}

QLabel#timeLabel {
    color: #94a3b8;
    font-size: 11px;
    font-family: monospace;
    background: transparent;
}

/* === SEEK SLIDER === */
QSlider#seekSlider {
    min-height: 20px;
    background: transparent;
}

QSlider#seekSlider::groove:horizontal {
    height: 4px;
    background: #334155;
    border-radius: 2px;
}

QSlider#seekSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #d946ef, stop:1 #06b6d4);
    border-radius: 2px;
}

QSlider#seekSlider::handle:horizontal {
    width: 14px;
    height: 14px;
    margin: -5px 0;
    background: #06b6d4;
    border: 2px solid #0f172a;
    border-radius: 7px;
}

QSlider#seekSlider::handle:horizontal:hover {
    background: #22d3ee;
    width: 16px;
    height: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

/* === CONTROL BAR === */
QFrame#controlBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1e293b, stop:1 #0f172a);
    border-top: 1px solid #334155;
}

QPushButton#transportBtn {
    background: transparent;
    color: #94a3b8;
    border: 1px solid #475569;
    border-radius: 4px;
    font-size: 18px;
    padding: 6px 12px;
    min-width: 40px;
}

QPushButton#transportBtn:hover {
    color: #06b6d4;
    border-color: #06b6d4;
    background: #334155;
}

QPushButton#transportBtn:pressed {
    background: #475569;
}

QPushButton#playBtn {
    background: #d946ef;
    color: #0f172a;
    border: none;
    border-radius: 22px;
    font-size: 20px;
    padding: 0px;
    min-width: 44px;
    min-height: 44px;
    max-width: 44px;
    max-height: 44px;
}

QPushButton#playBtn:hover {
    background: #e879f9;
}

QPushButton#playBtn:pressed {
    background: #c026d3;
}

QPushButton#modeBtn {
    background: transparent;
    color: #94a3b8;
    border: 1px solid #475569;
    border-radius: 4px;
    font-size: 16px;
    padding: 6px 10px;
    min-width: 36px;
}

QPushButton#modeBtn:hover {
    color: #cbd5e1;
    border-color: #64748b;
    background: #334155;
}

QPushButton#modeBtn:checked {
    color: #06b6d4;
    border-color: #06b6d4;
}

QPushButton#smallButton {
    background: transparent;
    color: #94a3b8;
    border: 1px solid #475569;
    border-radius: 3px;
    font-size: 10px;
    padding: 3px 8px;
    letter-spacing: 1px;
}

QPushButton#smallButton:hover {
    color: #06b6d4;
    border-color: #06b6d4;
}

QLabel#miniTitle {
    color: #94a3b8;
    font-size: 12px;
    background: transparent;
}

QLabel#volIcon {
    font-size: 16px;
    background: transparent;
    color: #94a3b8;
}

/* === VOLUME SLIDER === */
QSlider#volumeSlider {
    min-height: 18px;
    background: transparent;
}

QSlider#volumeSlider::groove:horizontal {
    height: 3px;
    background: #334155;
    border-radius: 1px;
}

QSlider#volumeSlider::sub-page:horizontal {
    background: #94a3b8;
    border-radius: 1px;
}

QSlider#volumeSlider::handle:horizontal {
    width: 10px;
    height: 10px;
    margin: -4px 0;
    background: #cbd5e1;
    border: 1px solid #0f172a;
    border-radius: 5px;
}

QSlider#volumeSlider::handle:horizontal:hover {
    background: #06b6d4;
}

/* === SCROLLBARS === */
QScrollBar:vertical {
    background: #0f172a;
    width: 8px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background: #475569;
    min-height: 30px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #64748b;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    height: 0px;
}

/* === INPUT DIALOGS === */
QInputDialog {
    background: #1e293b;
}

QInputDialog QLabel {
    color: #e2e8f0;
}

QInputDialog QLineEdit, QLineEdit#urlInput {
    background: #0f172a;
    color: #f8fafc;
    border: 1px solid #334155;
    border-radius: 3px;
    padding: 5px;
}

QInputDialog QPushButton {
    background: #334155;
    color: #e2e8f0;
    border: 1px solid #475569;
    border-radius: 3px;
    padding: 5px 15px;
}

QInputDialog QPushButton:hover {
    background: #06b6d4;
    color: #0f172a;
}

/* === TOOLTIPS === */
QToolTip {
    background: #1e293b;
    color: #06b6d4;
    border: 1px solid #334155;
    padding: 4px;
}
